# ── CGS Runtime Wrapper — environment variables ───────────────────────────────
# Copy this file to .env and fill in real values before running.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# API key sent by callers in the X-API-Key header.
# Generate a strong random value, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
CGS_API_KEY=change-me-to-a-strong-random-key

# Redis connection URL.
# Local:  redis://localhost:6379
# Docker Compose: redis://redis:6379 (overridden automatically by compose env block)
REDIS_URL=redis://localhost:6379

# ── Optional ──────────────────────────────────────────────────────────────────

# Anthropic API key — required only when MODEL_ADAPTER=claude.
# Obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Model adapter selection: stub | claude | openai
# stub  — returns a canned response; no external calls (default, safe for dev)
# claude — calls Anthropic Claude via ClaudeAPIAdapter
# openai — calls OpenAI via OpenAIAdapter placeholder
MODEL_ADAPTER=stub

# Claude model name used when MODEL_ADAPTER=claude.
CLAUDE_MODEL=claude-opus-4-6

# Rate limit: maximum POST /turn requests per session per minute.
# Default: 60
RATE_LIMIT_RPM=60
