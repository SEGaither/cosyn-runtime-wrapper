{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Compliance Rule",
  "type": "object",
  "required": [
    "rule_id",
    "name",
    "severity",
    "condition",
    "requirement",
    "failure_disposition"
  ],
  "properties": {
    "rule_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "S1",
        "S2",
        "S3",
        "S4"
      ]
    },
    "condition": {
      "type": "string"
    },
    "requirement": {
      "type": "string"
    },
    "failure_disposition": {
      "enum": [
        "warn",
        "conditional_pass",
        "block",
        "escalate"
      ]
    },
    "remediation_template": {
      "type": "string"
    }
  }
}