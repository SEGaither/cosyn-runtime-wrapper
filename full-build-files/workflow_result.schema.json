{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Workflow Result",
  "type": "object",
  "required": [
    "workflow_id",
    "artifact_id",
    "disposition",
    "conditions",
    "delivery_ready"
  ],
  "properties": {
    "workflow_id": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string"
    },
    "disposition": {
      "enum": [
        "approved",
        "approved_with_conditions",
        "rejected",
        "escalated"
      ]
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "delivery_ready": {
      "type": "boolean"
    }
  }
}