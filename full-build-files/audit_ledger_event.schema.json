{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Audit Ledger Event",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "event_timestamp_utc",
    "session_id",
    "workflow_id",
    "actor_type",
    "actor_id",
    "actor_role",
    "artifact_version",
    "input_refs",
    "transformation_summary",
    "assumptions_declared",
    "evidence_basis",
    "confidence_score",
    "compliance_status",
    "human_review_required",
    "outcome_state",
    "hash_prev",
    "hash_current"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "event_timestamp_utc": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "actor_type": {
      "enum": [
        "agent",
        "human",
        "system"
      ]
    },
    "actor_id": {
      "type": "string"
    },
    "actor_role": {
      "type": "string"
    },
    "parent_event_id": {
      "type": "string"
    },
    "artifact_id": {
      "type": "string"
    },
    "artifact_version": {
      "type": "string"
    },
    "input_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_ref": {
      "type": "string"
    },
    "transformation_summary": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "assumptions_declared": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_basis": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "compliance_status": {
      "enum": [
        "not_reviewed",
        "in_review",
        "approved",
        "approved_with_conditions",
        "rejected",
        "blocked"
      ]
    },
    "human_review_required": {
      "type": "boolean"
    },
    "outcome_state": {
      "enum": [
        "informational",
        "pending",
        "completed",
        "blocked",
        "escalated",
        "voided"
      ]
    },
    "hash_prev": {
      "type": "string"
    },
    "hash_current": {
      "type": "string"
    }
  }
}